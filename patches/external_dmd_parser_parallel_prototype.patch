+version (ParserParallelPrototype)
+private int parserThreadsFromEnv()
+{
+    const(char)* v = getenv("DMD_PARSE_THREADS");
+    if (!v || !v[0])
+        return 1;
+
+    const int parsed = atoi(v);
+    if (parsed <= 1)
+        return 1;
+
+    return parsed > 64 ? 64 : parsed;
+}
+
+version (ParserParallelPrototype)
+private bool parserDiagnosticsEnabled()
+{
+    const(char)* v = getenv("DMD_PARSE_DIAGNOSTICS");
+    return v && v[0] && v[0] != '0';
+}
+
+version (ParserParallelPrototype)
+private bool parserLockModeIsNarrow()
+{
+    const(char)* v = getenv("DMD_PARSE_LOCK_MODE");
+    return v && v[0] && strcmp(v, "narrow") == 0;
+}
+
+version (ParserParallelPrototype)
+private bool parseRootModulesInParallel(ref Modules modules, int threads)
+{
+    if (threads <= 1 || modules.length < 2)
+        return false;
+
+    Object parseLock = new Object();
+    const useNarrow = parserLockModeIsNarrow();
+
+    Thread createParseWorker(ref Modules modulesRef, size_t start, size_t stride)
+    {
+        return new Thread(
+            {
+                for (size_t i = start; i < modulesRef.length; i += stride)
+                {
+                    auto m = modulesRef[i];
+                    if (m)
+                    {
+                        if (!useNarrow)
+                        {
+                            // Coarse mode preserves the original correctness-first prototype.
+                            synchronized (parseLock)
+                                m.parse();
+                        }
+                        else
+                            m.parse();
+                    }
+                }
+            }
+        );
+    }
+
+    Thread[] workers;
+    workers.length = cast(size_t) threads;
+    const stride = cast(size_t) threads;
+
+    foreach (tid; 0 .. threads)
+    {
+        const workerId = cast(size_t) tid;
+        workers[workerId] = createParseWorker(modules, workerId, stride);
+        workers[workerId].start();
+    }
+
+    foreach (w; workers)
+        w.join();
+
+    if (parserDiagnosticsEnabled())
+        fprintf(stderr, "parse-parallel-diag summary mode=%s queue_ms=0 parse_ms=0 commit_ms=0 total_ms=0 requested=%d used=%d modules=%llu\n",
+            (useNarrow ? "narrow" : "coarse").ptr,
+            threads,
+            threads,
+            cast(ulong) modules.length);
+
+    return true;
+}
